# ── Zoho People DB — Employee Agent ──────────────────────────────────────
ZOHO_DB_HOST=zohodb.alignedautomation.com
ZOHO_DB_PORT=5432
ZOHO_DB_NAME=zohodb
ZOHO_DB_USER=reporting_user
