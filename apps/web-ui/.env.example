# ─────────────────────────────────────────────────────────────────────────────
# AURA Web UI — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local or .env.production.local and update values
# for your specific deployment environment
#
# Usage:
#   .env.local        — Development overrides (git ignored)
#   .env.production   — Production defaults
#   .env.staging      — Staging defaults
#
# React will automatically load these based on NODE_ENV
# ─────────────────────────────────────────────────────────────────────────────

# ─── API Configuration ──────────────────────────────────────────────────────
# Set the API base URL. If not provided, defaults will be used based on NODE_ENV
#
# Development (default): http://localhost:8000
# Staging (default):     https://api-staging.aligned.com
# Production (default):  https://api.aligned.com
#
REACT_APP_API_URL=http://localhost:8000

# ─── Azure AD / MSAL Configuration ──────────────────────────────────────────
# Configure Azure AD authentication
REACT_APP_TENANT_ID=your-tenant-id
REACT_APP_CLIENT_ID=your-client-id
REACT_APP_REDIRECT_URI=http://localhost:3000

# ─── Feature Flags ──────────────────────────────────────────────────────────
# Enable/disable experimental features
REACT_APP_ENABLE_STREAMING=true
REACT_APP_ENABLE_DARK_MODE=true

# ─── Analytics & Monitoring ────────────────────────────────────────────────
# Optional: Configure analytics services
REACT_APP_GA_TRACKING_ID=
REACT_APP_SENTRY_DSN=

# ─── App Configuration ──────────────────────────────────────────────────────
# App name and branding
REACT_APP_NAME=AURA
REACT_APP_VERSION=1.0

# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT INSTRUCTIONS:
# 
# 1. Development (Local):
#    npm start
#    Uses .env.local (if exists) or defaults to http://localhost:8000
#
# 2. Staging Deployment:
#    npm run build
#    Set REACT_APP_API_URL=https://api-staging.aligned.com
#    Deploy to staging server
#
# 3. Production Deployment:
#    npm run build
#    Set REACT_APP_API_URL=https://api.aligned.com
#    Deploy to production server
#
# Example Docker build with environment:
#    docker build \
#      --build-arg REACT_APP_API_URL=https://api.aligned.com \
#      -t aura-web-ui:latest .
# ─────────────────────────────────────────────────────────────────────────────
